# ─────────────────────────────────────────────────────────────
# ResQNet Backend — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=5001

# Database
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/resqnet?retryWrites=true&w=majority

# Redis
REDIS_URL=redis://127.0.0.1:6379

# Authentication (CHANGE THESE IN PRODUCTION!)
JWT_SECRET=your_super_secure_jwt_secret_at_least_32_characters_long
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS
CLIENT_URL=http://localhost:3000,http://localhost:3001

# Cloudinary (optional — for image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# AI Providers (optional — at least one for AI features)
OPENAI_API_KEY=
GEMINI_API_KEY=
AI_DEFAULT_PROVIDER=openai

# Notifications (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Maps (optional)
MAPBOX_ACCESS_TOKEN=
GOOGLE_MAPS_API_KEY=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Encryption (32 bytes hex = 64 chars)
ENCRYPTION_KEY=
